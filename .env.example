SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback

# Kindle (key-based SSH, no password)
KINDLE_IP=
KINDLE_SSH_USER=root
KINDLE_PORT=2222
# Path to private key generated by setup-ssh-key.sh (stored outside the repo).
# Example: ~/.ssh/kindle_lyrical
KINDLE_KEY=~/.ssh/kindle_lyrical
FBINK_PATH=/mnt/us/koreader/fbink
# Touchscreen evdev for tap-to-exit; any tap clears the screen and quits.
# event1 is the PW3 panel; change if `ls /dev/input` on your Kindle differs.
KINDLE_TOUCH_EVENT=/dev/input/event1
# TrueType font ON THE KINDLE for nice glyphs; leave blank for the bitmap font
FONT_PATH=/usr/java/lib/fonts/Helvetica_LT_65_Medium.ttf

POLL_SECONDS=2
# Seconds to add to Spotify's reported position to compensate for API + SSH latency.
# Increase if lyrics still lag; decrease if they appear too early. Default: 1.5
LYRIC_OFFSET_S=1.5

# Display (fbink bypasses KOReader, so set rotation & sizes here)
# KINDLE_ROTA writes /sys/class/graphics/fb0/rotate (Linux fb rotate value).
# On a Kindle Paperwhite (native portrait device): 0=portrait, 1=landscape,
# 2=portrait flipped, 3=landscape flipped. Start with 1; use 3 if text is
# upside-down. NOTE: FBINK_FORCE_ROTA does NOT work on PW3.
KINDLE_ROTA=1
LYRIC_PX=120
HEADER_PX=48
